<%= turbo_stream_from @board %>

<div data-controller="filter">
<header class="topbar">
  <div class="topbar-left">
    <h1>Cardinal AI <span class="sep">▸</span> <span id="board-name"><%= @board.name %></span></h1>
    <%= link_to "⚙", edit_board_path, data: { turbo_frame: "modal" }, class: "gear",
          title: "Board settings — name, default branch" %>
    <%= button_to "⇣ Pull", pull_board_path, form_class: "pull-form",
          form: { title: "git pull --ff-only in #{@board.local_path} — fetch what Done has merged" },
          data: { turbo_submits_with: "⇣ Pulling…" }, class: "theme-toggle" %>
    <%# Repo deep dive (card #12): one-shot read-only mapping of the repo, stored
        as a brief and injected into worker prompts. The button greys→reds as the
        brief falls behind HEAD; a stale brief over-anchors, so it nags at 10+.
        Once a brief exists the button opens it for inspection (the modal holds
        the Regenerate action) — a fresh brief is never silently re-run. %>
    <% behind = @board.commits_behind_brief %>
    <% if @board.brief_working? %>
      <button type="button" class="deep-dive working" disabled>
        <span class="pulse-dot"></span> Deep dive · working…
      </button>
    <% elsif @board.brief? %>
      <%= link_to brief_board_path, data: { turbo_frame: "modal" },
            class: "deep-dive#{' stale-critical' if @board.brief_stale?}",
            style: "color: #{@board.brief_staleness_color}; border-color: #{@board.brief_staleness_color}",
            title: "Repo brief from #{@board.brief_sha&.first(7)} · #{@board.brief_generated_at&.to_date} — click to inspect" do %>
        <% if behind&.positive? %>
          🔍 Repo brief · <%= behind %> commit<%= "s" if behind != 1 %> behind
        <% else %>
          🔍 Repo brief
        <% end %>
      <% end %>
    <% else %>
      <%= button_to deep_dive_board_path, class: "deep-dive",
            title: "Map this repo into a brief agents reuse — saves exploration on every run" do %>
        🔍 Deep dive
      <% end %>
    <% end %>
    <span id="repo-pull-status"></span>
  </div>
  <div class="topbar-center">
    <input type="search" id="global-search" class="global-search" placeholder="Search cards…  /"
           data-filter-target="global"
           data-action="input->filter#global keydown->filter#clear">
  </div>
  <div class="topbar-right">
    <button type="button" class="theme-toggle"
            data-controller="theme" data-action="theme#toggle">☀ Light</button>
    <% if ENV["CARDINAL_AUTH"].present? %>
      <span class="auth-chip" title="<%= ENV["CARDINAL_AUTH"] == "dedicated" ? "This board runs as its own linked Claude account (.cardinal/claude). Switch with: cardinal login" : "This board inherits the machine's claude login (CARDINAL_INHERIT_AUTH=1)" %>">
        🔐 <%= ENV["CARDINAL_AUTH"] == "dedicated" ? "board account" : "machine account" %>
      </span>
    <% end %>
    <% attention = @board.attention_cards %>
    <% working = @board.cards.where(status: "working").order(:updated_at) %>
    <% queued = @board.cards.where(status: "queued").order(:position) %>
    <% if attention.any? || working.any? || queued.any? %>
      <details class="attention">
        <summary>
          <% if attention.any? %><span class="attn-part">⚠ <%= attention.size %> need you</span><% end %>
          <% if working.any? %><span class="attn-part working-part"><span class="pulse-dot"></span> <%= working.size %> working</span><% end %>
          <% if queued.any? %><span class="attn-part">⏳ <%= queued.size %> queued</span><% end %>
        </summary>
        <div class="attention-list">
          <% if attention.any? %>
            <p class="attn-header">Needs you</p>
            <ul>
              <% attention.each do |card| %>
                <li><%= link_to "##{card.number} #{card.title} — #{card.status.humanize.downcase}",
                                card_path(card), data: { turbo_frame: "modal", turbo_action: "advance" } %></li>
              <% end %>
            </ul>
          <% end %>
          <% if working.any? %>
            <p class="attn-header">Working</p>
            <ul>
              <% working.each do |card| %>
                <li class="attn-working">
                  <span class="pulse-dot"></span>
                  <%= link_to card_path(card), data: { turbo_frame: "modal", turbo_action: "advance" } do %>
                    #<%= card.number %> <%= card.title %><span class="hint"> — <%= card.latest_progress&.truncate(60) || "starting…" %></span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% end %>
          <% if queued.any? %>
            <p class="attn-header">Queued</p>
            <ul>
              <% queued.each_with_index do |card, index| %>
                <li><%= link_to "##{card.number} #{card.title} — #{index.zero? ? "next up" : "#{index} ahead"}",
                                card_path(card), data: { turbo_frame: "modal", turbo_action: "advance" } %></li>
              <% end %>
            </ul>
          <% end %>
        </div>
      </details>
    <% end %>
    <% archived_count = @board.cards.archived.count %>
    <%= link_to "🗄#{" #{archived_count}" if archived_count.positive?}", archive_board_path,
          class: "theme-toggle", title: "Archive — archived cards, searchable and restorable" %>
    <details class="new-column">
      <summary>+ Column</summary>
      <%= form_with url: columns_path, class: "new-column-form" do |f| %>
        <%= f.text_field "column[name]", placeholder: "Column name", required: true %>
<%# Inbox is the board's single intake — it can't be created a second time (card #17). %>
        <%= f.select "column[archetype]",
              (Column::ARCHETYPES - %w[inbox]).map { |a| [a.capitalize, a] }, selected: "planning" %>
        <%= f.submit "Add" %>
      <% end %>
    </details>
  </div>
</header>

<main class="board">
  <% @board.columns.each do |column| %>
    <%= render "columns/column", column: column %>
  <% end %>
</main>
</div>

<%= turbo_frame_tag "modal", data: { turbo_permanent: true } do %>
  <%= render "cards/detail" if @card %>
<% end %>
