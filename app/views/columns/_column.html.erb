<section class="column column-<%= column.archetype %>" id="<%= dom_id(column) %>"
         data-col-id="<%= column.id %>" data-accepts="<%= Array(column.accepts_from).join(",") %>"<%= " style=\"background-color: #{column.safe_color}\"".html_safe if column.safe_color %>>
  <header class="column-header">
    <span class="column-title">
      <h2><%= column.name %></h2>
      <% if column.inbox? %>
        <%= link_to "+", new_card_path, class: "add-card", title: "New card",
                    data: { turbo_frame: "modal" } %>
      <% end %>
    </span>
    <span class="col-tools">
      <button type="button" class="col-search-toggle" title="Filter this column"
              data-action="filter#toggle">🔍</button>
      <%= link_to "⚙", edit_column_path(column), class: "gear", title: "Column settings",
                  data: { turbo_frame: "modal" } %>
    </span>
  </header>
  <input type="search" class="col-search" placeholder="Filter <%= column.name %>…"
         data-col-id="<%= column.id %>"
         data-action="input->filter#column keydown->filter#clear">
  <% if column.inbox? %>
    <%# Quick-add (card #42): title, Enter, done — the modal stays for real write-ups. %>
    <%= form_with url: cards_path, class: "quick-add", data: { turbo_frame: "_top" } do |f| %>
      <%= f.text_field "card[title]", placeholder: "Quick add — type a title, press Enter",
            autocomplete: "off", required: true %>
    <% end %>
  <% end %>
  <p class="drop-hint">→ <%= column.drag_hint %></p>
  <div class="cards<%= " cards-clickable" if column.inbox? %>"
       data-controller="board-column"
       data-board-column-hint-value="<%= column.drag_hint %>"
       <% if column.inbox? %>data-action="click->board-column#newCard"
       data-board-column-new-url-value="<%= new_card_path %>"<% end %>
       data-column-id="<%= column.id %>">
    <% column.cards.active.each do |card| %>
      <%= render "cards/card", card: card %>
    <% end %>
  </div>
  <% rows = column.footer_rows %>
  <% if rows.any? %>
    <footer class="column-footer">
      <% rows.each do |row| %>
        <div class="footer-row">
          <span class="footer-label"><%= row[:label] %></span>
          <span class="footer-value"><%= row[:value] %></span>
        </div>
      <% end %>
    </footer>
  <% end %>
</section>
