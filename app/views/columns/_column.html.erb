<section class="column column-<%= column.archetype %>" id="<%= dom_id(column) %>"<%= " style=\"background-color: #{column.safe_color}\"".html_safe if column.safe_color %>>
  <header class="column-header">
    <h2><%= column.name %></h2>
    <%= link_to "⚙", edit_column_path(column), class: "gear", title: "Column settings",
                data: { turbo_frame: "modal" } %>
  </header>
  <p class="drop-hint">→ <%= column.drag_hint %></p>
  <div class="cards"
       data-controller="board-column"
       data-board-column-hint-value="<%= column.drag_hint %>"
       data-column-id="<%= column.id %>">
    <% column.cards.each do |card| %>
      <%= render "cards/card", card: card %>
    <% end %>
  </div>
  <% if column.inbox? %>
    <%= link_to "+ New Card", new_card_path, class: "new-card-btn",
                data: { turbo_frame: "modal" } %>
  <% end %>
</section>
