<article class="card status-<%= card.status %>" id="<%= dom_id(card) %>" data-card-id="<%= card.id %>">
  <%= link_to card_path(card), class: "card-link" do %>
    <div class="card-title">
      <span class="card-number">#<%= card.number %></span> <%= card.title %>
      <span class="status-glyph"><%= { "working" => "⚡", "needs_input" => "❓", "failed" => "✖",
                                       "work_complete" => "✅", "done" => "✓", "queued" => "⏳",
                                       "discussing" => "💬" }[card.status] %></span>
    </div>
    <% if card.latest_progress %>
      <p class="card-progress">▸ <%= card.latest_progress %></p>
    <% elsif card.needs_attention? %>
      <p class="card-progress attention-text"><%= card.status.humanize %></p>
    <% end %>
    <div class="card-meta">
      <% card.tags.each do |tag| %><span class="tag"><%= tag %></span><% end %>
      <% if card.branch_name %><span class="chip branch">🌿 <%= card.pr_url ? "PR" : card.branch_name.delete_prefix("cardinal/") %></span><% end %>
    </div>
  <% end %>
</article>
