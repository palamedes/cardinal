<%= turbo_frame_tag "modal" do %>
  <div class="modal-backdrop" data-controller="modal" data-action="click->modal#backdrop">
    <div class="modal card-detail">
      <%= turbo_stream_from @card %>
      <header class="modal-header">
        <h1>
          <span class="card-number">#<%= @card.number %></span> <%= @card.title %>
          <span class="chip status-chip status-<%= @card.status %>"><%= @card.status.humanize %></span>
        </h1>
        <div class="modal-header-right">
          <% if @card.branch_name %>
            <span class="git-line">🌿 <%= @card.branch_name %><% if @card.pr_url %> → <%= link_to "PR", @card.pr_url, target: "_blank" %> (<%= @card.pr_state %>)<% end %></span>
          <% end %>
          <button type="button" class="modal-close" data-action="modal#close" title="Close (Esc)">✕</button>
        </div>
      </header>

      <div class="detail-panes">
        <section class="timeline">
          <nav class="zoom-tabs">
            <% %w[conversation activity debug].each do |zoom| %>
              <%= link_to zoom.capitalize, card_path(@card, zoom: zoom),
                          class: ("active" if @zoom == zoom) %>
            <% end %>
          </nav>

          <% if @card.description.present? %>
            <div class="event event-description"><%= simple_format @card.description %></div>
          <% end %>

          <div id="card_events">
            <%= render partial: "events/event", collection: @events %>
            <% if @events.empty? %>
              <p class="empty">No events yet — this card hasn't been anywhere.</p>
            <% end %>
          </div>

          <%= form_with url: card_messages_path(@card), class: "message-form" do |f| %>
            <%= f.text_area "message[text]", rows: 2, required: true,
                  placeholder: @card.column.planning? ? "Discuss this card with the planning assistant…" : "Add a note to this card…" %>
            <%= f.submit "Send" %>
          <% end %>
        </section>

        <aside class="work-panel">
          <h3>Details</h3>
          <%= form_with model: @card, class: "card-edit" do |f| %>
            <label>Title</label>
            <%= f.text_field :title, required: true %>
            <label>Tags <span class="hint">(comma separated)</span></label>
            <%= f.text_field :tags, value: @card.tags.join(", ") %>
            <label>Description</label>
            <%= f.text_area :description, rows: 6 %>
            <%= f.submit "Save" %>
          <% end %>

          <h3>Work</h3>
          <p class="empty">Plan progress, artifacts, and run controls appear here once the runner lands.</p>
        </aside>
      </div>
    </div>
  </div>
<% end %>
